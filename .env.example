# Copy to .env (or export in your shell) and fill in.

# --- LLM provider: OpenAI ChatGPT (GPT-5.5) ---
OPENAI_API_KEY=sk-...
# Model used by the translator and the LLM-as-judge eval.
SAS2SPARK_LLM_MODEL=gpt-5.5
# Optional: override the OpenAI base URL (Azure / proxy / gateway).
# OPENAI_BASE_URL=https://api.openai.com/v1
# Primary provider: "openai" (default), "anthropic", or "stub" (offline).
SAS2SPARK_LLM_PROVIDER=openai

# --- Secondary / fallback provider: Anthropic Claude ---
# If the primary errors (quota, auth, outage), calls route here automatically.
# Set SAS2SPARK_LLM_FALLBACK_PROVIDER=none to disable.
SAS2SPARK_LLM_FALLBACK_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
SAS2SPARK_ANTHROPIC_MODEL=claude-opus-4-8

# --- Translation target ---
# pyspark is the only supported target in v2.
SAS2SPARK_TARGET=pyspark

# --- Pipeline knobs ---
SAS2SPARK_MAX_REPAIR_ATTEMPTS=3
SAS2SPARK_FLOAT_TOLERANCE=1e-9
